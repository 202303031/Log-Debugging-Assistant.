# ============================================
# Streamlit Secrets Template
# ============================================
# Copy this file to secrets.toml and fill in your values.
#
# For Streamlit Community Cloud:
#   Go to your app settings → Secrets → paste the contents below.
#
# For local development:
#   Copy to .streamlit/secrets.toml
# ============================================

# Google AI Studio API Key (free at https://aistudio.google.com/apikey)
GOOGLE_API_KEY = "your-google-api-key-here"

# Supabase PostgreSQL Connection String
# Format: postgresql://user:password@host:port/dbname
# Get this from Supabase Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL = "postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:5432/postgres"
